# Surfaced - API keys for AI providers
# Copy to .env and fill in the keys you need:
#   cp .env.example .env

# At least one API key is required to run prompts.

# Anthropic (for anthropic_api provider)
ANTHROPIC_API_KEY=

# OpenAI (for openai_api provider)
OPENAI_API_KEY=

# Google Gemini (for gemini_api provider)
GEMINI_API_KEY=

# ClickHouse connection
# Local (default): no changes needed.
# ClickHouse Cloud: populated automatically by `surfaced bootstrap --cloud`,
# or set HOST/USER/PASSWORD and CLICKHOUSE_SECURE=true manually.
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=                  # default 8123, or 8443 when CLICKHOUSE_SECURE=true
# CLICKHOUSE_USER=default
# CLICKHOUSE_PASSWORD=
# CLICKHOUSE_DATABASE=default
# CLICKHOUSE_SECURE=false           # set to true for ClickHouse Cloud

# ClickHouse Cloud bootstrap (required for `surfaced bootstrap --cloud`)
# Create an Admin API key at https://console.clickhouse.cloud > Settings > API Keys.
# CLICKHOUSE_CLOUD_API_KEY=
# CLICKHOUSE_CLOUD_API_SECRET=
# CLICKHOUSE_CLOUD_ORG_ID=          # auto-detected if you only belong to one org
# CLICKHOUSE_CLOUD_SERVICE_NAME=surfaced
# CLICKHOUSE_CLOUD_PROVIDER=aws     # aws | gcp | azure
# CLICKHOUSE_CLOUD_REGION=us-east-1
