# Surfaced - API keys for AI providers
# Copy to .env and fill in the keys you need:
#   cp .env.example .env

# At least one API key is required to run campaigns.

# Anthropic (for anthropic_api provider)
ANTHROPIC_API_KEY=

# OpenAI (for openai_api provider)
OPENAI_API_KEY=

# Google Gemini (for gemini_api provider)
GEMINI_API_KEY=

# ClickHouse connection (defaults shown, usually no change needed)
# CLICKHOUSE_HOST=localhost
# CLICKHOUSE_PORT=8123
